# Database connection string
# Local:  mongodb://127.0.0.1/your-database-name
# Vercel: MongoDB Atlas connection string (mongodb+srv://...)
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash.
# Local:  http://localhost:3000
# Vercel: https://your-domain.vercel.app  (or your custom domain)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Cloudinary — required for media uploads to persist on Vercel.
# Get these from https://console.cloudinary.com/ (Dashboard → Product Environment Credentials)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET
